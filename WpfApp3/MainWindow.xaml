<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="Авторизация" Height="600" Width="450">
    <Grid>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel Margin="40">

                <TextBlock Text="Авторизация" HorizontalAlignment="Center"></TextBlock>

                <TextBox Margin="10 10" Name="LoginEnter"></TextBox>

                <PasswordBox Margin="10 10" Name="PasswordEnter"></PasswordBox>

                <Button x:Name="LoginButton" Click="LoginButton_Click" Content="Войти" HorizontalAlignment="Center" Margin="40 10"></Button>

                <TextBlock Text="Войти как гость" HorizontalAlignment="Center" FontSize="15" MouseDown="TextBlock_MouseDown"></TextBlock>
                
            </StackPanel>
            
        </Border>
        
    </Grid>
</Window>
